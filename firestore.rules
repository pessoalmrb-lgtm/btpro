rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "pamonhashouse@gmail.com" && 
        request.auth.token.email_verified == true
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // ENTITY VALIDATION HELPERS
    // ===============================================================

    function isValidUser(data) {
      let req = ['uid', 'email', 'userTag', 'userNumericId', 'isPremium', 'createdAt'];
      // Use size check to prevent shadow fields
      return data.keys().hasAll(req) && (data.keys().size() >= 6 && data.keys().size() <= 10) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.userTag is string && data.userTag.size() <= 50 &&
             data.userNumericId is string && data.userNumericId.size() <= 20 &&
             data.isPremium is bool &&
             data.createdAt is int;
    }

    function isValidRanking(data) {
      let req = ['id', 'name', 'ownerId', 'adminIds', 'pointsConfig', 'createdAt'];
      return data.keys().hasAll(req) && (data.keys().size() >= 6 && data.keys().size() <= 15) &&
             data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.ownerId is string &&
             data.adminIds is list && data.adminIds.size() <= 100 &&
             data.pointsConfig is map &&
             data.createdAt is int;
    }

    function isValidTournament(data) {
      let req = ['id', 'name', 'uid', 'players', 'matches', 'currentRound', 'totalRounds', 'tables', 'format', 'matchFormat', 'registrationType', 'isFinished', 'createdAt'];
      return data.keys().hasAll(req) && (data.keys().size() >= 13 && data.keys().size() <= 25) &&
             data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.uid is string &&
             data.players is list && data.players.size() <= 200 &&
             data.matches is list && data.matches.size() <= 1000 &&
             data.currentRound is int &&
             data.totalRounds is int &&
             data.tables is list && data.tables.size() <= 100 &&
             data.isFinished is bool &&
             data.createdAt is int;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{userId} {
      // Secure List Queries
      allow list: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && (
        isValidUser(incoming()) &&
        incoming().uid == existing().uid &&
        incoming().createdAt == existing().createdAt && (
          isAdmin() ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'userTag', 'userNumericId', 'subscriptionExpiresAt']) &&
           incoming().isPremium == existing().isPremium)
        )
      );
    }

    match /rankings/{rankingId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(rankingId) && isValidRanking(incoming()) && incoming().ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (existing().ownerId == request.auth.uid || request.auth.uid in existing().adminIds || isAdmin()) &&
        isValidRanking(incoming()) &&
        incoming().ownerId == existing().ownerId &&
        incoming().createdAt == existing().createdAt && (
          isAdmin() ||
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'arenaName', 'adminIds', 'logoUrl', 'coverUrl', 'pointsConfig', 'leagueAthletes', 'athleteIds', 'playerStats', 'address'])
        )
      );
      
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());

      match /players/{playerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
          (exists(/databases/$(database)/documents/rankings/$(rankingId)) && (
            request.auth.uid == get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId ||
            request.auth.uid in get(/databases/$(database)/documents/rankings/$(rankingId)).data.adminIds
          )) ||
          isAdmin()
        );
      }
    }

    match /tournaments/{tournamentId} {
      // Secure List Queries
      allow list: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        isAdmin() ||
        (resource.data.get('rankingId', null) != null && request.auth.uid in get(/databases/$(database)/documents/rankings/$(resource.data.rankingId)).data.athleteIds)
      );
      allow get: if isSignedIn();

      allow create: if isSignedIn() && isValidId(tournamentId) && isValidTournament(incoming()) && 
                      incoming().uid == request.auth.uid && (
                        incoming().get('rankingId', null) == null || 
                        exists(/databases/$(database)/documents/rankings/$(incoming().rankingId))
                      );
      
      allow update: if isSignedIn() && (
        (existing().uid == request.auth.uid || isAdmin()) &&
        isValidTournament(incoming()) &&
        incoming().uid == existing().uid &&
        incoming().createdAt == existing().createdAt && (
          isAdmin() ||
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'players', 'matches', 'currentRound', 'totalRounds', 'tables', 
            'format', 'matchFormat', 'registrationType', 'isFinished', 'isHidden', 
            'rankingId', 'championsPhotoUrl', 'finalResults', 'matches_group_stage', 
            'matches_knockout_stage', 'teamsPerGroup', 'playoffRounds'
          ])
        )
      );
      
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }
  }
}
