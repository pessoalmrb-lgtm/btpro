// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tournaments
// Document ID: tournamentId
// Fields:
//   - id: string (required)
//   - name: string (required, 1-100 chars)
//   - uid: string (required, immutable) - Owner's UID
//   - players: list (required, max 100 items)
//   - matches: list (required, max 500 items)
//   - currentRound: number (required)
//   - totalRounds: number (required)
//   - tables: list (required, max 20 items)
//   - format: string (required)
//   - matchFormat: string (required)
//   - registrationType: string (required)
//   - rankingCriteria: list (required, max 10 items)
//   - isFinished: bool (required)
//   - createdAt: number (required, immutable)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && request.auth.uid == resource.data.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "pamonhashouse@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // Validation Blueprint for Tournament
    function isValidTournament(data) {
      let requiredFields = ['id', 'name', 'uid', 'players', 'matches', 'currentRound', 'totalRounds', 'tables', 'format', 'matchFormat', 'registrationType', 'rankingCriteria', 'isFinished', 'createdAt'];
      let optionalFields = ['teamsPerGroup', 'playoffRounds'];
      
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.uid is string &&
             data.players is list && data.players.size() <= 100 &&
             data.matches is list && data.matches.size() <= 1000 &&
             data.currentRound is int &&
             data.totalRounds is int &&
             data.tables is list && data.tables.size() <= 50 &&
             data.format is string &&
             data.matchFormat is string &&
             data.registrationType is string &&
             data.rankingCriteria is list && data.rankingCriteria.size() <= 10 &&
             data.isFinished is bool &&
             data.createdAt is int &&
             (!data.keys().contains('teamsPerGroup') || data.teamsPerGroup is int) &&
             (!data.keys().contains('playoffRounds') || data.playoffRounds is list);
    }

    // Validation Blueprint for Ranking
    function isValidRanking(data) {
      let requiredFields = ['id', 'name', 'ownerId', 'adminIds', 'pointsConfig', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.ownerId is string && data.ownerId.size() > 0 &&
             data.adminIds is list && data.adminIds.size() <= 100 &&
             (!data.keys().contains('athleteIds') || (data.athleteIds is list && data.athleteIds.size() <= 5000)) &&
             (!data.keys().contains('leagueAthletes') || (data.leagueAthletes is list && data.leagueAthletes.size() <= 5000)) &&
             data.pointsConfig is map &&
             data.createdAt is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /rankings/{rankingId} {
      allow read: if isSignedIn(); // Rankings can be public or discovered
      
      allow create: if isSignedIn() && 
                      isValidId(rankingId) &&
                      isValidRanking(incoming()) && 
                      incoming().ownerId == request.auth.uid;
      
        allow update: if isSignedIn() && (
                        // 1. Admins/Owner can update everything (obeying isValidRanking)
                        ((request.auth.uid == existing().ownerId || request.auth.uid in existing().adminIds || isAdmin()) && 
                         isValidRanking(request.resource.data) &&
                         request.resource.data.ownerId == existing().ownerId) 
                        ||
                        // 2. Athletes (including non-admins) can always remove themselves
                        (isSignedIn() &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['adminIds', 'leagueAthletes', 'athleteIds']) &&
                         // Security: Must not be in the new athleteIds or adminIds lists
                         !(request.auth.uid in request.resource.data.get('athleteIds', [])) &&
                         !(request.auth.uid in request.resource.data.get('adminIds', [])) &&
                         // Verification: Must have been a member (either in athleteIds, adminIds, or have a player record)
                         (request.auth.uid in existing().get('athleteIds', []) || 
                          request.auth.uid in existing().get('adminIds', []) ||
                          exists(/databases/$(database)/documents/rankings/$(rankingId)/players/$(request.auth.uid))))
                      );
      
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());

      match /players/{playerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
          // Admin of the ranking or global admin
          (exists(/databases/$(database)/documents/rankings/$(rankingId)) && 
           (request.auth.uid in get(/databases/$(database)/documents/rankings/$(rankingId)).data.adminIds ||
            request.auth.uid == get(/databases/$(database)/documents/rankings/$(rankingId)).data.ownerId)) ||
          // User deleting their own document when leaving
          request.auth.uid == playerId ||
          isAdmin()
        );
      }
    }

    match /tournaments/{tournamentId} {
      allow read: if isDocOwner() || isAdmin() || 
                  (isSignedIn() && existing().get('rankingId', null) != null && 
                   request.auth.uid in get(/databases/$(database)/documents/rankings/$(existing().rankingId)).data.athleteIds);
      
      allow create: if isSignedIn() && 
                      isValidId(tournamentId) &&
                      isValidTournament(incoming()) && 
                      incoming().uid == request.auth.uid;
      
      allow update: if (isDocOwner() || isAdmin()) && 
                      isValidTournament(request.resource.data) && 
                      request.resource.data.uid == existing().uid &&
                      request.resource.data.createdAt == existing().createdAt;
      
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      incoming().keys().hasAll(['uid', 'email', 'isPremium']) &&
                      incoming().uid == request.auth.uid;
                      
      allow update: if isOwner(userId) && (
        // Allow updating specific fields or anything by admin
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'userTag', 'userNumericId', 'isPremium', 'subscriptionExpiresAt']) || isAdmin()
      );
    }
  }
}
